{
  "name": "mcp-gateway",
  "version": "1.0.0",
  "description": "MCP proxy/gateway that aggregates multiple MCP servers behind a single SSE/HTTP endpoint",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:fleet": "MCP_GATEWAY_CONFIG=config.fleet.yaml node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "harness": "node dist/resilience-harness.js",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest",
    "audit:contracts": "tsx scripts/audit-contracts.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^4.0.3",
    "express": "^4.21.0",
    "node-vault": "^0.10.9",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "vitest": "^3.2.6",
    "fast-uri": ">=3.1.2",
    "express-rate-limit": ">=8.2.2",
    "@hono/node-server": ">=1.19.13",
    "hono": ">=4.12.21",
    "ip-address": ">=10.1.1",
    "qs": ">=6.15.2",
    "uuid": ">=11.1.1",
    "esbuild": ">=0.25.0",
    "vite": ">=6.4.2",
    "path-to-regexp": ">=8.4.0",
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "router": {
      "path-to-regexp": ">=8.4.0"
    }
  }
}
