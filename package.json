{
  "name": "mcp-gateway",
  "version": "1.0.0",
  "description": "MCP proxy/gateway that aggregates multiple MCP servers behind a single SSE/HTTP endpoint",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:fleet": "MCP_GATEWAY_CONFIG=config.fleet.yaml node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "harness": "node dist/resilience-harness.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chokidar": "^4.0.3",
    "express": "^4.21.0",
    "node-vault": "^0.10.10",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
